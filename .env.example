# ===== 火山引擎豆包（竞品 + 可能当裁判）=====
# 控制台 https://console.volcengine.com/ark 创建接入点(endpoint)，拿到 API Key 与 endpoint id
ARK_API_KEY=
# 豆包 endpoint id，形如 ep-2025xxxx-xxxxx
DOUBAO_ENDPOINT_ID=

# ===== 待评测的自研 agent（若对外是 OpenAI 兼容接口）=====
MY_AGENT_BASE_URL=http://localhost:8000/v1
MY_AGENT_API_KEY=
MY_AGENT_MODEL=default

# ===== 其他竞品 / 裁判模型（复用你已有的 key）=====
GEMINI_API_KEY=
KIMI_API_KEY=

# ===== 裁判联网检索：三选一 =====
TAVILY_API_KEY=
SERPAPI_API_KEY=
BING_API_KEY=

# ===== 语义相似度 embedding（可选；不填则退化到字符/词重叠相似度）=====
OPENAI_API_KEY=
